{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://kpm.komdigi.go.id/schemas/scraped_item.schema.json",
  "title": "ScrapedItem",
  "description": "Schema for a single crawled item from Google Trends or Trend24. Taxonomy: taxonomy-kpm — 3 kategori_utama, 11 sub_kategori",
  "type": "object",
  "required": [
    "id",
    "source_platform",
    "keyword",
    "scraped_at",
    "kategori_utama",
    "sub_kategori",
    "sentimen",
    "prioritas"
  ],
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "UUID v4 generated by the scraper before insert. Primary key in Supabase."
    },
    "source_platform": {
      "type": "string",
      "enum": [
        "GTR",
        "T24"
      ],
      "description": "GTR = Google Trends, T24 = Trend24."
    },
    "keyword": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500,
      "description": "Trending keyword or phrase as extracted from the source platform."
    },
    "url": {
      "type": [
        "string",
        "null"
      ],
      "format": "uri",
      "description": "Canonical URL of the trend or item page. Null if not applicable."
    },
    "scraped_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 UTC timestamp of when the item was scraped. Example: 2026-03-13T07:00:00Z"
    },
    "trend_date": {
      "type": [
        "string",
        "null"
      ],
      "format": "date",
      "description": "Date the trend was reported as active on the source platform. May differ from scraped_at."
    },
    "rank": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 1,
      "description": "Rank position of the keyword on the source platform at time of scraping."
    },
    "search_volume": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 0,
      "description": "Estimated search volume or mention count as reported by the source."
    },
    "volume_label": {
      "type": [
        "string",
        "null"
      ],
      "description": "Human-readable volume label verbatim from source. E.g. '50K+', '100K+', 'Breakout', 'Trending'."
    },
    "related_queries": {
      "type": [
        "array",
        "null"
      ],
      "description": "Related or co-trending keywords from the same source page.",
      "items": {
        "type": "string"
      }
    },
    "geo": {
      "type": "object",
      "description": "Geographic scope of the trend.",
      "properties": {
        "country": {
          "type": "string",
          "default": "ID",
          "description": "ISO 3166-1 alpha-2 country code."
        },
        "region": {
          "type": [
            "string",
            "null"
          ],
          "description": "Province or region name if region-specific. Null for national scope."
        }
      },
      "required": [
        "country"
      ]
    },
    "kategori_utama": {
      "type": "string",
      "enum": [
        "POG",
        "ECD",
        "SEH"
      ],
      "description": "Top-level category. POG = Politics & Governance, ECD = Economy & Development, SEH = Social Environment & Health."
    },
    "sub_kategori": {
      "type": "string",
      "enum": [
        "IPH",
        "KLP",
        "KPM",
        "KSD",
        "KBS",
        "ILT",
        "EKD",
        "KTK",
        "LKS",
        "PSD",
        "KSB"
      ],
      "description": "Second-level category. Must be consistent with kategori_utama: POG->IPH/KLP/KPM/KSD, ECD->KBS/ILT/EKD/KTK, SEH->LKS/PSD/KSB."
    },
    "sentimen": {
      "type": "string",
      "enum": [
        "POS",
        "NEG",
        "NET"
      ],
      "description": "POS = Positif, NEG = Negatif, NET = Netral."
    },
    "prioritas": {
      "type": "string",
      "enum": [
        "T",
        "S",
        "R"
      ],
      "description": "T = Tinggi (<24h), S = Sedang (<3 days), R = Rendah (routine monitoring)."
    },
    "is_auto_labeled": {
      "type": "boolean",
      "default": true,
      "description": "True if labels were assigned by the AI model. False if manually reviewed."
    },
    "confidence_score": {
      "type": [
        "number",
        "null"
      ],
      "minimum": 0.0,
      "maximum": 1.0,
      "description": "Model confidence score for sub_kategori classification (0.0-1.0). Null if manually labeled."
    },
    "ews_flag": {
      "type": "boolean",
      "default": false,
      "description": "True if this item triggered an Early Warning System alert."
    },
    "ews_reason": {
      "type": [
        "string",
        "null"
      ],
      "description": "Reason for EWS flag. Null when ews_flag is false."
    },
    "raw_payload": {
      "type": [
        "object",
        "null"
      ],
      "description": "Verbatim crawl4ai JSON output before normalization. For audit and replay."
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "UTC timestamp of database insert. Set by Supabase default (now())."
    },
    "updated_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time",
      "description": "UTC timestamp of last row update. Set by Supabase trigger."
    }
  },
  "additionalProperties": false,
  "examples": [
    {
      "id": "a1b2c3d4-0001-4abc-8def-111122223333",
      "source_platform": "GTR",
      "keyword": "judi online Jawa Tengah",
